# ============================================================
# Discord Gamble Bot - 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=gamble_bot
POSTGRES_USER=gamble_user
POSTGRES_PASSWORD=changeme_strong_password

# --- Webサーバー (Express.js) ---
# docker-compose 内から db コンテナに接続する場合
DATABASE_URL=postgresql://gamble_user:changeme_strong_password@db:5432/gamble_bot
SERVER_PORT=3000
# 管理者権限判定に使用するトークン（推測困難なランダム文字列を設定すること）
ADMIN_TOKEN=replace_with_a_secure_random_token

# --- Discord Bot ---
DISCORD_TOKEN=your_discord_bot_token_here
# スラッシュコマンド登録スクリプト (deploy-commands) でのみ使用
DISCORD_CLIENT_ID=your_discord_application_id_here
DISCORD_GUILD_ID=your_discord_server_id_here
DISCORD_ADMIN_ROLE_ID=your_admin_role_id_here
# Bot から API サーバーへの接続先（docker-compose 内では service 名を使用）
API_BASE_URL=http://server:3000
# /admin-link コマンドで返す管理者用 Webアプリの公開 URL
WEB_APP_BASE_URL=https://your-github-pages-url.example.com

# --- Webアプリ (React / Vite) ---
# ブラウザから API を呼び出す際のベース URL（nginx 経由の場合は /api）
VITE_API_BASE_URL=/api

# --- 共通 ---
NODE_ENV=development
